APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
AUTH_REQUIRED=false

DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

PDF_PATH=data/raw/Bhagavad-Gita As It Is.pdf
PROCESSED_VERSES_PATH=data/processed/verses.jsonl
PROCESSED_CHUNKS_PATH=data/processed/chunks.jsonl
CORPUS_REPORT_PATH=data/processed/corpus_report.json
FAISS_INDEX_PATH=data/index/faiss.index
FAISS_METADATA_PATH=data/index/metadata.json

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_DEVICE=cpu
VECTOR_STORE_PROVIDER=faiss

LLM_PROVIDER=modal
MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1
MODAL_API_KEY=
MODAL_MODEL=zai-org/GLM-5.1-FP8
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.35
MAX_MESSAGE_CHARS=4000
MAX_HISTORY_TURNS=6
MAX_HISTORY_CHARS=8000
MEMORY_CONTEXT_WINDOW=5
STREAM_WORD_DELAY_MS=16
ALLOW_EMPTY_INDEX=false
HF_TOKEN=
