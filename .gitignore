.DS_Store

# ENV (keep ignored)

.env
.env.*
!.env.example

# Python

.venv/
**pycache**/
.pytest_cache/
*.pyc
*.egg-info/

# Node / Next.js

node_modules/
.next/
out/
npm-debug.log*

# ❌ Ignore raw PDF (large + not needed in prod)

*.pdf
!backend/tests/fixtures/**/*.pdf
backend/data/raw/*
!backend/data/raw/.gitkeep

# ✅ KEEP processed + index (CRITICAL for deployment)

# (Do NOT ignore these anymore)

# backend/data/processed/*

# backend/data/index/*

# Only ignore local fixtures

backend/data/fixtures/local/*
!backend/data/fixtures/local/.gitkeep

